<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Warna berikut diselaraskan dengan variabel CSS tema "teal" (default)
      pada :root di index.html, supaya elemen native Android (status bar,
      splash, widget) tidak "belang" dengan WebView-nya:
        p   (primary)            : #006A6A
        pc  (primary container)  : #9DF0EF
        opc (on primary container): #002020
        bg  (background)         : #F4FBFB
        err (error)              : #BA1A1A
    -->
    <color name="nf_primary">#006A6A</color>
    <color name="nf_primary_container">#9DF0EF</color>
    <color name="nf_on_primary_container">#002020</color>
    <color name="nf_background">#F4FBFB</color>
    <color name="nf_error">#BA1A1A</color>

    <color name="nf_primary_dark_theme">#9DF0EF</color>
    <color name="nf_background_dark_theme">#0E1414</color>

    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>
</resources>
